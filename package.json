    "type": "git",
    "url": "git+https://github.com/CatalinaNicoleta98/BOOKORA-backend.git"
  },
  "license": "ISC",
  "author": "Catalina",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "build": "rm -rf ./dist && tsc",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "test": "playwright test",
    "seed:demo": "cross-env ENABLE_DEMO_SEEDER=true SEED_SCENARIO=demo SEED_MODE=reset ts-node ./src/seed/index.ts",
    "seed:demo:clear": "cross-env ENABLE_DEMO_SEEDER=true SEED_SCENARIO=demo SEED_MODE=clear ts-node ./src/seed/index.ts"
  },
  "nodemonConfig": {
    "verbose": false,
    "watch": [
      "src"
    ],
    "ext": "js,ts",
    "exec": "npx ts-node ./src/index.ts",
    "ignore": [
      "node_modules"
    ]
  },
  "dependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
   "@types/nodemailer": "^8.0.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv-flow": "^4.1.0",
    "express": "^5.2.1",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^7.0.0",
    "mongoose": "^9.1.5",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.7",
    "nodemon": "^3.1.11",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/axios": "^0.9.36",
    "@types/express": "^5.0.6",
    "@types/joi": "^17.2.2",
    "@types/node": "^25.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
