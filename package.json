{
  "name": "bookora-backend",
  "version": "1.0.0",
  "description": "Bookora full stack project semester 2",
  "homepage": "https://github.com/CatalinaNicoleta98/BOOKORA-backend#readme",
  "bugs": {
    "url": "https://github.com/CatalinaNicoleta98/BOOKORA-backend/issues"
